{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"name": "Playfair Display",
					"slug": "playfair-display",
					"fontFamily": "'Playfair Display', serif"
				},
				{
					"name": "Lato",
					"slug": "lato",
					"fontFamily": "'Lato', sans-serif"
				}
			],
			"fontSizes": [
				{
					"name": "Small",
					"slug": "small",
					"size": "14px",
					"fluid": false
				},
				{
					"name": "Paragraph",
					"slug": "paragraph",
					"size": "clamp(14px, 13.3px + 0.19vw, 16px)",
					"fluid": false
				},
				{
					"name": "Link",
					"slug": "link",
					"size": "clamp(16px, 15.3px + 0.19vw, 18px)",
					"fluid": false
				},
				{
					"name": "Medium",
					"slug": "medium",
					"size": "clamp(16px, 15.3px + 0.19vw, 18px)",
					"fluid": false
				},
				{
					"name": "H3",
					"slug": "h3",
					"size": "clamp(24px, 21.2px + 0.75vw, 32px)",
					"fluid": false
				},
				{
					"name": "H2",
					"slug": "h2",
					"size": "clamp(32px, 26.4px + 1.5vw, 48px)",
					"fluid": false
				},
				{
					"name": "H1",
					"slug": "h1",
					"size": "clamp(40px, 31.5px + 2.25vw, 64px)",
					"fluid": false
				}
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var:preset|font-family|lato",
			"fontSize": "var:preset|font-size|paragraph",
			"fontWeight": "400",
			"lineHeight": "1.6",
			"letterSpacing": "0.05em"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|playfair-display",
					"fontWeight": "400",
					"lineHeight": "1.2",
					"letterSpacing": "0.05em"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|h1",
					"fontWeight": "400"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|h2",
					"fontWeight": "400"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|h3",
					"fontWeight": "400"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var:preset|font-family|playfair-display",
					"fontSize": "clamp(20px, 17.2px + 0.75vw, 28px)",
					"fontWeight": "400"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var:preset|font-family|playfair-display",
					"fontSize": "clamp(18px, 16.1px + 0.5vw, 24px)",
					"fontWeight": "400"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var:preset|font-family|playfair-display",
					"fontSize": "clamp(16px, 14.6px + 0.38vw, 20px)",
					"fontWeight": "400"
				}
			},
			"link": {
				"typography": {
					"fontFamily": "var:preset|font-family|lato",
					"fontSize": "var:preset|font-size|link",
					"fontWeight": "400",
					"letterSpacing": "0.05em"
				},
				"color": {
					"text": "currentColor"
				},
				":hover": {
					"typography": {
						"textDecoration": "none"
					}
				}
			},
			"button": {
				"typography": {
					"fontFamily": "var:preset|font-family|lato",
					"fontSize": "var:preset|font-size|link",
					"fontWeight": "700",
					"letterSpacing": "0.05em"
				},
				"color": {
					"background": "linear-gradient(to bottom, #B59A5A, #D5C59C)",
					"text": "#ffffff"
				},
				"border": {
					"radius": "5px"
				},
				":hover": {
					"color": {
						"background": "color-mix(in srgb, var(--wp--preset--color--contrast) 85%, transparent)",
						"text": "var:preset|color|base"
					},
					"border": {
						"color": "transparent"
					}
				},
				":focus": {
					"outline": {
						"color": "var:preset|color|accent-4",
						"offset": "2px"
					}
				},
				"spacing": {
					"padding": {
						"bottom": "1rem",
						"left": "2.25rem",
						"right": "2.25rem",
						"top": "1rem"
					}
				}
			}
		}
	}
}